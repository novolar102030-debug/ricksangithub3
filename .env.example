# ─── CNX CMS — Variáveis de Ambiente ─────────────────────────────────────────
#
# Copie este arquivo para .env e preencha os valores.
# Em produção (Vercel), configure estas variáveis no painel do projeto.
#

# Chave secreta para assinar os cookies de sessão do admin.
# Use qualquer string longa e aleatória. NUNCA compartilhe este valor.
# Exemplo: openssl rand -hex 32
ADMIN_SECRET=troque_por_uma_chave_secreta_longa_e_aleatoria

# Senha para acessar a página /setup (opcional).
# Se definida, a página de instruções de deploy exige senha antes de exibir o conteúdo.
# Deixe em branco para deixar a página aberta.
# SETUP_PAGE_PASSWORD=minha_senha_secreta
